{
  "name": "atlas-ai-travel-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx workers/index.ts",
    "test": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "next typegen && tsc --noEmit",
    "migrate": "prisma migrate dev",
    "seed": "tsx db/seed.ts",
    "clean": "rimraf .next coverage dist"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@trpc/server": "10.45.4",
    "bullmq": "5.80.8",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "ics": "3.8.1",
    "leaflet": "1.9.4",
    "lucide-react": "0.468.0",
    "next": "16.2.10",
    "pino": "9.5.0",
    "pino-pretty": "11.3.0",
    "prisma": "5.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "superjson": "2.2.1",
    "zod": "3.23.8",
    "zustand": "5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.2",
    "@types/leaflet": "1.9.14",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "10.4.20",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "husky": "9.1.6",
    "jsdom": "25.0.1",
    "lefthook": "1.8.2",
    "lint-staged": "15.5.2",
    "postcss": "8.5.19",
    "prettier": "3.3.3",
    "rimraf": "6.0.1",
    "tailwindcss": "3.4.14",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,json,css,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
