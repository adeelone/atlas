{
  "name": "atlas-ai-travel-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx workers/index.ts",
    "test": "vitest run --coverage --pool=forks --poolOptions.forks.singleFork=true",
    "lint": "next lint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "migrate": "prisma migrate dev",
    "seed": "tsx db/seed.ts",
    "clean": "rimraf .next coverage dist"
  },
  "dependencies": {
    "@prisma/client": "7.8.0",
    "@tanstack/react-query": "4.36.1",
    "@trpc/client": "10.45.2",
    "@trpc/next": "10.45.2",
    "@trpc/react-query": "10.45.2",
    "@trpc/server": "10.45.2",
    "bullmq": "5.21.2",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "ics": "3.8.1",
    "leaflet": "1.9.4",
    "lucide-react": "0.468.0",
    "next": "14.2.16",
    "next-auth": "4.24.10",
    "pino": "9.5.0",
    "pino-pretty": "11.3.0",
    "prisma": "5.22.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "superjson": "2.2.1",
    "zod": "3.23.8",
    "zustand": "5.0.1"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@playwright/test": "1.48.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@types/leaflet": "1.9.14",
    "@types/node": "22.8.7",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.3",
    "@vitest/coverage-v8": "2.1.4",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.16",
    "husky": "9.1.6",
    "jsdom": "25.0.1",
    "lefthook": "1.8.2",
    "lint-staged": "15.2.10",
    "postcss": "8.4.49",
    "prettier": "3.3.3",
    "rimraf": "6.0.1",
    "tailwindcss": "3.4.14",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,json,css,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
