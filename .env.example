# Postgres connection used by Prisma.
DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas"

# Redis is used for cache and BullMQ jobs.
REDIS_URL="redis://localhost:6379"

# NextAuth local URL and development secret placeholder.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-in-development"

# Google OAuth, used later for login and calendar export.
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email provider placeholder for magic links and invites.
RESEND_API_KEY="your-resend-api-key"

# LLM provider selection: mock, openai, anthropic, or ollama.
LLM_PROVIDER="mock"
OPENAI_API_KEY="your-openai-api-key"
ANTHROPIC_API_KEY="your-anthropic-api-key"
OLLAMA_BASE_URL="http://localhost:11434"

# Map provider selection: leaflet by default, mapbox when a token is set.
MAP_PROVIDER="leaflet"
MAPBOX_TOKEN="your-mapbox-token"

# Feature flags.
ENABLE_LIVE_MODE="true"
ENABLE_OCR_UPLOADS="false"
ENABLE_PAID_PROVIDERS="false"

# Local object storage for documents in Docker.
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="atlas-dev-access-key"
MINIO_SECRET_KEY="atlas-dev-secret-key"
